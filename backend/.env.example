# Copy to .env and fill in real values. Do not commit .env.
# Required in production (use a long random string):
SECRET_KEY=your-secret-key-here

# Set to production when deploying. Use development only locally.
# FLASK_ENV=production
# FLASK_ENV=development

# Database (defaults to SQLite in instance/ if not set)
# DATABASE_URL=sqlite:///site.db

# Optional: mail (if using Flask-Mail)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Stripe (for business billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
